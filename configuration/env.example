# Copy this file to configuration/.env and fill in your values.
# Crawler and structural-analysis options live in configuration/.operations-crawl
# and configuration/.operations-structural (TOML). Each starts with hard-coded
# defaults from webapp_engine/config/defaults.py; the Operations panel's
# "Save as defaults" button writes a file with the current selections.


# ── General ───────────────────────────────────────────────────────────────────

LANGUAGE_CODE="en-us"
TIME_ZONE="UTC"


# ── Django internals ──────────────────────────────────────────────────────────

SECRET_KEY=xxx
DEBUG=True
ALLOWED_HOSTS=.localhost, 127.0.0.1


# ── Database ──────────────────────────────────────────────────────────────────

# SQLite (default)
DB_ENGINE=sqlite
DB_NAME=db.sqlite3

# PostgreSQL (set DB_ENGINE=postgresql and fill in the fields below)
# DB_ENGINE=postgresql
# DB_NAME=pulpit
# DB_USER=pulpit
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

# MySQL / MariaDB (set DB_ENGINE=mysql or DB_ENGINE=mariadb)
# DB_ENGINE=mysql
# DB_NAME=pulpit
# DB_USER=pulpit
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=3306

# Oracle (set DB_ENGINE=oracle; DB_NAME is the service name or DSN)
# DB_ENGINE=oracle
# DB_NAME=ORCL
# DB_USER=pulpit
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=1521


# ── Telegram credentials ──────────────────────────────────────────────────────
# Required. Get your API ID and hash at https://core.telegram.org/api/obtaining_api_id

TELEGRAM_API_ID=123
TELEGRAM_API_HASH=xxx
TELEGRAM_PHONE_NUMBER=+123


# ── Telegram client tuning ────────────────────────────────────────────────────
# Optional. Defaults shown are the values used when these vars are unset.

# TELEGRAM_SESSION_NAME=anon                # Telethon session-file basename
# TELEGRAM_CONNECTION_RETRIES=10            # retries on initial connect
# TELEGRAM_RETRY_DELAY=5                    # seconds between connect retries
# TELEGRAM_FLOOD_SLEEP_THRESHOLD=60         # auto-sleep if Telegram asks ≤ N seconds
# TELEGRAM_IGNORE_FLOODWAIT=True            # don't sleep on flood-wait (resume next run)
# TELEGRAM_FLOODWAIT_SLEEP_SECONDS=900      # sleep duration when IGNORE_FLOODWAIT=False
# TELEGRAM_CRAWLER_GRACE_TIME=1             # per-request pause to be polite to Telegram


# ── Project ───────────────────────────────────────────────────────────────────

PROJECT_TITLE=Pulpit project
WEB_ACCESS=ALL  # ALL (no login required), OPEN (admin+ops require staff), PROTECTED (everything requires login)

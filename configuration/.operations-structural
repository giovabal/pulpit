# Pulpit operations defaults — structural analysis
# Saved through the Operations panel ("Save as defaults") or hand-edited.
# The [meta] section's `title` and `pulpit_version` identify the snapshot;
# future Pulpit releases use `pulpit_version` to migrate the file in place.

[meta]
title = "Pulpit defaults"
pulpit_version = "0.21"
generated_at = "2026-05-21T00:00:00Z"

[graph]
dead_leaves_color = "#000000"
community_palette = "vaporwave"
community_palette_reversed = true
output_dir = "graph"

[outputs]
graph = true
graph_3d = false
html = true
xlsx = false
gexf = false
graphml = false
csv = false
seo = false
vertical_layout = false
structural_similarity = false
consensus_matrix = false
draw_dead_leaves = false
timeline_step = "none"

[edges]
weight_strategy = "PARTIAL_REFERENCES"
include_mentions = true
include_self_references = false

[scope]
include_lost = false
include_private = false

[computation]
fa2_iterations = "7x"
community_distribution_threshold = 10
leiden_coarse_resolution = 0.01
leiden_fine_resolution = 0.05
mcl_inflation = 2.0
spreading_runs = 200
diffusion_window = 30

[layouts]
layouts_2d = ["FA2", "CIRCULAR", "KAMADA_KAWAI", "COMMUNITY_SHELL", "TSNE", "UMAP", "HYPERBOLIC"]
layouts_3d = ["FA2", "SPECTRAL", "SPRING", "KAMADA_KAWAI", "TSNE", "UMAP"]

[measures]
# Webapp form default: Tier 3 (structural-only) + Tier 4 (valid) measures under the one-degree
# amplification model — see docs/network-measures.md → "Interpretation guardrails". Path/flow
# measures (BETWEENNESS, SPREADING, TROPHICLEVEL, BROKERAGEROLES, BRIDGING*, HARMONICCENTRALITY,
# COLLECTIVEINFLUENCE, CORENESS) are omitted by default but remain selectable.
selected = ["PAGERANK", "HITSHUB", "HITSAUTH", "INDEGCENTRALITY", "OUTDEGCENTRALITY", "BURTCONSTRAINT", "LOCALCLUSTERING", "MODULEROLE", "AMPLIFICATION", "CONTENTORIGINALITY", "DIFFUSIONLAG"]
bridging_basis = ""

[communities]
# Algorithmic community-detection strategies pre-selected in the form. LEIDEN_DIRECTED reads
# one-degree co-citation directly (see docs/community-detection.md → "Interpretation guardrails:
# density vs. flow"); LEIDEN, LEIDEN_CPM, LOUVAIN, LABELPROPAGATION, KCORE and SBM stay selectable.
strategies = ["LEIDEN_DIRECTED"]
# Manual label-group partitions (Operations panel → "Label groups"). DB-keyed LABELGROUP<id> tokens,
# so the committed baseline leaves them empty — pick the groups per analysis. Nodes are still coloured
# by the primary label group by default even when none is selected here.
label_groups = []

[network_stats]
groups = ["SIZE", "PATHS", "COHESION", "COMPONENTS", "DEGCORRELATION", "CENTRALIZATION", "CONTENT"]

[vacancy]
measures = ["STRUCTURAL_EQUIV", "BROKERAGE"]
months_before = 12
months_after = 24
max_candidates = 30

[robustness]
alpha = 0.05
# Webapp form default: random (baseline) + in_strength (degree) + pagerank (prestige)
# + betweenness (bridges / cut positions — the canonical fragmentation attack, Holme et al. 2002).
# An attack *order* is a topological cut heuristic judged by its effect on the S(f) curves, not a
# per-channel flow claim, so betweenness sits inside the one-degree guardrails the way REACH does.
# subscribers (audience-targeted moderation) and the *_dyn variants are off by default but remain
# selectable. See docs/robustness-analysis.md → "Interpretation guardrails".
strategies = ["random", "in_strength", "pagerank", "betweenness"]
runs = 100
null = 20
seed = 42
sample = 500
